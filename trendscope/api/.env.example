# TrendScope API 环境变量
# 复制为 .env 并修改

# 服务器
TS_API_PORT=8001
TS_DEBUG=true

# 数据库（共享已有实例）
TS_DB_HOST=localhost
TS_DB_PORT=5432
TS_DB_USER=trendscope
TS_DB_PASSWORD=trendscope_dev
TS_DB_NAME=trendscope

# Redis（共享已有实例）
TS_REDIS_HOST=localhost
TS_REDIS_PORT=6379
TS_REDIS_DB=3

# JWT（与已有平台共享密钥）
PO_SECRET_KEY=change-me-in-production

# Celery
TS_CELERY_BROKER=redis://localhost:6379/4
TS_CELERY_BACKEND=redis://localhost:6379/5

# 外部 API Keys（采集用）
YOUTUBE_API_KEY=your-youtube-api-key
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TIKTOK_PROXY_URL=http://proxy-user:proxy-pass@host:port

# 功能开关
FEATURE_GATES_PATH=/srv/projects/feature_gates.yaml

# 管道联动
AGGREGATOR_API_URL=http://localhost:8000/api/v1/content/fetch

# ═══════════════════════════════════════════════
# 代理配置（采集爬虫用）
# ═══════════════════════════════════════════════
# PROXY_MODE 可选值:
#   xiaoxiang  - 小象代理 提取API（IP列表，自动轮换）
#   tunnel     - 隧道代理（固定地址，自动轮换）
#   none       - 直连（仅测试，本机IP会暴露！）
PROXY_MODE=none

# ─── 小象代理 提取API (xiaoxiang) ───
# 在小象后台"产品管理"页面找到你的应用，生成API链接后填入:
#   登录 xiaoxiangdaili.com → 产品管理 → 找到应用 → API提取
# 复制整个链接填入 PROXY_API_URL
# PROXY_API_URL=https://api.xiaoxiangdaili.com/ip/get?appKey=xxx&appSecret=yyy&wt=json
# PROXY_REFRESH_INTERVAL=60  # IP刷新间隔（秒），小象短效IP只有2-5分钟寿命
#                            # 建议设为60-120s，在IP过期前主动换新
# 每次提取会消耗IP额度(包量套餐)，注意剩余量，用完需续费

# ─── 隧道代理 (tunnel) ───
# PROXY_TUNNEL_HOST=tps123.kdlapi.com
# PROXY_TUNNEL_PORT=15818
# PROXY_USERNAME=your-username
# PROXY_PASSWORD=your-password
